# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# LLM provider: claude | openai_compat
LLM_PROVIDER=claude
LLM_MODEL=claude-opus-4-8

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# OpenAI-compatible endpoint (optional; used when LLM_PROVIDER=openai_compat)
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Run generated DAX against a running Power BI Desktop (EVALUATE). See README.
ENABLE_LIVE_VALIDATION=true
